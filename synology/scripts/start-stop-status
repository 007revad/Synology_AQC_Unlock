#!/bin/sh

set -eu

# Package Center invokes this script as the restricted package user, which has
# no permission to write to the sysfs paths this package needs (new_id, unbind,
# remove_id, disable_ipv6) or to bring up interfaces / run dhclient. Rather than
# sprinkling sudo through every privileged line, hand off entirely to the real
# logic script running as root via a scoped, NOPASSWD sudoers entry.
exec sudo -n /var/packages/AQC_Unlock/scripts/start-stop-status-root "$@"
