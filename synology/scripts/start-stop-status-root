#!/bin/sh

set -eu

PKG_NAME="AQC_Unlock"
VAR_DIR="/var/packages/${PKG_NAME}/var"
STATE_DIR="${VAR_DIR}/state"
LOG_FILE="${VAR_DIR}/aquantia.log"

# Real DSM atlantic modules on this system (not bundled with the package)
ATLANTIC_MODULES="/lib/modules/atlantic.ko /lib/modules/atlantic_v2.ko"

AQUANTIA_VENDOR="0x1d6a"

NETSCRIPTS_DIR="/etc/sysconfig/network-scripts"
OVS_INTERFACE_CONF="/usr/syno/etc/synoovs/ovs_interface.conf"
SYNOINFO="/etc/synoinfo.conf"

# Self-contained modinfo access via the multi-call kmod binary
MODINFO_LINK="${VAR_DIR}/modinfo"

log_message() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE" 2>/dev/null || true
    # The package's own var/ directory is deleted on uninstall, so also mirror
    # every line to the system log - this is the only copy that survives it,
    # and it's how you'd confirm the uninstall teardown actually completed.
    logger -t AQC_Unlock "$1" 2>/dev/null || true
}

log_identity() {
    mkdir -p "$VAR_DIR" 2>/dev/null || true
    id_output=$(id 2>&1 || true)
    log_message "Invoked as: ${id_output}"
}

ensure_modinfo() {
    mkdir -p "$VAR_DIR" 2>/dev/null || true
    if [ ! -e "$MODINFO_LINK" ]; then
        ln -sf /bin/kmod "$MODINFO_LINK" 2>/dev/null || true
    fi
}

# Extract VVVV:DDDD pairs (uppercase hex) a given .ko's alias table claims,
# ignoring subsystem vendor/device fields entirely.
get_supported_ids() {
    modpath="$1"
    [ -f "$modpath" ] || return 0
    "$MODINFO_LINK" modinfo "$modpath" 2>/dev/null | grep "^alias:" | \
        sed -n 's/.*pci:v0000\([0-9A-Fa-f]\{4\}\)d0000\([0-9A-Fa-f]\{4\}\).*/\1:\2/p' | \
        tr 'a-f' 'A-F'
}

# Poll a PCI device's sysfs node for its resulting net interface name(s)
wait_for_iface() {
    dev_path="$1"
    tries=0
    while [ "$tries" -lt 20 ]; do
        if [ -d "${dev_path}net" ]; then
            ifaces=$(ls "${dev_path}net" 2>/dev/null || true)
            if [ -n "$ifaces" ]; then
                echo "$ifaces"
                return 0
            fi
        fi
        sleep 1
        tries=$((tries + 1))
    done
    return 1
}

# Read a KEY=value (optionally quoted) field from an ifcfg-style file.
# Returns empty string (not an error) if the file or key is missing.
get_ifcfg_value() {
    file="$1"
    key="$2"
    [ -f "$file" ] || return 0
    grep "^${key}=" "$file" 2>/dev/null | tail -1 | cut -d= -f2- | tr -d '"' || true
}

# Mirrors rc.network's get_mtu_value(): reads "<iface>_mtu" from synoinfo.conf
get_mtu_value() {
    iface="$1"
    get_ifcfg_value "$SYNOINFO" "${iface}_mtu"
}

# Create a new OVS bridge for a given physical interface, reading any existing
# DSM configuration for that interface (BOOTPROTO/IPADDR/NETMASK/IPV6INIT) so a
# user's prior explicit choice for this slot is respected exactly, mirroring
# what rc.network's check_external_interface_for_ovs()/activate_ovs() do.
create_ovs_bridge_for() {
    iface="$1"
    bridge="ovs_${iface}"
    ethcfg="${NETSCRIPTS_DIR}/ifcfg-${iface}"
    ovscfg="${NETSCRIPTS_DIR}/ifcfg-${bridge}"

    ethcfg_existed="yes"
    if [ ! -f "$ethcfg" ]; then
        ethcfg_existed="no"
        log_message "No existing ifcfg-${iface}, creating a minimal DHCP default"
        {
            echo "DEVICE=${iface}"
            echo "BOOTPROTO=dhcp"
            echo "ONBOOT=yes"
            echo "IPV6INIT=auto"
        } > "$ethcfg"
    fi

    bootproto=$(get_ifcfg_value "$ethcfg" "BOOTPROTO")
    [ -n "$bootproto" ] || bootproto="dhcp"
    ipv6init=$(get_ifcfg_value "$ethcfg" "IPV6INIT")
    [ -n "$ipv6init" ] || ipv6init="auto"
    ipaddr=$(get_ifcfg_value "$ethcfg" "IPADDR")
    netmask=$(get_ifcfg_value "$ethcfg" "NETMASK")

    log_message "${iface}: BOOTPROTO=${bootproto} IPV6INIT=${ipv6init}${ipaddr:+ IPADDR=${ipaddr}}${netmask:+ NETMASK=${netmask}}"

    # Register this physical interface with DSM's OVS tracking, and mark it as
    # bridged - matching exactly what rc.network's boot-time scan would write.
    if ! grep -qx "$iface" "$OVS_INTERFACE_CONF" 2>/dev/null; then
        echo "$iface" >> "$OVS_INTERFACE_CONF"
    fi
    /usr/syno/bin/synosetkeyvalue "$ethcfg" BRIDGE "$bridge" 2>/dev/null || true

    # Create the bridge's own ifcfg file
    /usr/syno/bin/synosetkeyvalue "$ovscfg" DEVICE "$bridge" 2>/dev/null || true
    /usr/syno/bin/synosetkeyvalue "$ovscfg" BOOTPROTO "$bootproto" 2>/dev/null || true
    /usr/syno/bin/synosetkeyvalue "$ovscfg" ONBOOT yes 2>/dev/null || true
    /usr/syno/bin/synosetkeyvalue "$ovscfg" TYPE OVS 2>/dev/null || true
    /usr/syno/bin/synosetkeyvalue "$ovscfg" PRIMARY "$iface" 2>/dev/null || true
    /usr/syno/bin/synosetkeyvalue "$ovscfg" IPV6INIT "$ipv6init" 2>/dev/null || true
    /usr/syno/bin/synosetkeyvalue "$ovscfg" IPV6_ACCEPT_RA 1 2>/dev/null || true
    if [ "$bootproto" = "static" ]; then
        [ -n "$ipaddr" ] && /usr/syno/bin/synosetkeyvalue "$ovscfg" IPADDR "$ipaddr" 2>/dev/null || true
        [ -n "$netmask" ] && /usr/syno/bin/synosetkeyvalue "$ovscfg" NETMASK "$netmask" 2>/dev/null || true
    fi

    # Create the live bridge, matching rc.network's activate_ovs() sequence
    if ! ovs-vsctl br-exists "$bridge" 2>/dev/null; then
        ovs-vsctl add-br "$bridge"
        log_message "Created OVS bridge ${bridge}"
    fi

    physmac=$(cat "/sys/class/net/${iface}/address" 2>/dev/null || true)
    if [ -n "$physmac" ]; then
        ovs-vsctl set bridge "$bridge" other-config:hwaddr="$physmac" 2>/dev/null || true
    fi

    ip addr flush dev "$iface" 2>/dev/null || true
    ip link set "$iface" up 2>/dev/null || true

    # DSM unconditionally disables IPv6 on the physical bridge-member port,
    # regardless of the user's IPV6INIT choice - the bridge is what carries
    # the real setting.
    if [ -f "/proc/sys/net/ipv6/conf/${iface}/disable_ipv6" ]; then
        echo 1 > "/proc/sys/net/ipv6/conf/${iface}/disable_ipv6" 2>/dev/null || true
    fi

    if ! ovs-vsctl list-ports "$bridge" 2>/dev/null | grep -qx "$iface"; then
        ovs-vsctl add-port "$bridge" "$iface"
    fi

    mtu_value=$(get_mtu_value "$iface")
    if [ -n "$mtu_value" ]; then
        ifconfig "$iface" mtu "$mtu_value" 2>/dev/null || true
    fi

    ip link set "$bridge" up 2>/dev/null || true

    if [ "$ipv6init" = "off" ]; then
        if [ -f "/proc/sys/net/ipv6/conf/${bridge}/disable_ipv6" ]; then
            echo 1 > "/proc/sys/net/ipv6/conf/${bridge}/disable_ipv6" 2>/dev/null || true
        fi
        log_message "${bridge}: IPv6 Off (per ${iface}'s DSM setting) - disabled"
    else
        log_message "${bridge}: IPv6 setting is '${ipv6init}' - left enabled"
    fi

    if [ "$bootproto" = "static" ]; then
        if [ -n "$ipaddr" ] && [ -n "$netmask" ]; then
            if [ -n "$mtu_value" ]; then
                ifconfig "$bridge" "$ipaddr" netmask "$netmask" mtu "$mtu_value" 2>/dev/null || true
            else
                ifconfig "$bridge" "$ipaddr" netmask "$netmask" 2>/dev/null || true
            fi
            log_message "${bridge}: applied static ${ipaddr}/${netmask}"
        else
            log_message "${bridge}: BOOTPROTO=static but IPADDR/NETMASK missing, not configuring an address"
        fi
    else
        lf="/tmp/dhcpv4.leases.${bridge}"
        pf="/tmp/dhcpcd-${bridge}.pid"
        /usr/sbin/dhclient -4 -d -q \
            -lf "$lf" \
            -pf "$pf" \
            -cf /etc/dhclient/ipv4/dhclient.conf \
            -sf /var/run/dhclient-script \
            "$bridge" >/dev/null 2>&1 &
        log_message "Started dhclient for ${bridge} (pidfile ${pf})"
    fi

    # Record everything teardown needs: iface|bridge|bootproto|ethcfg_existed
    echo "${iface}|${bridge}|${bootproto}|${ethcfg_existed}" >> "${STATE_DIR}/ovs_bridges"
}

teardown_ovs_bridge_for() {
    iface="$1"
    bridge="$2"
    bootproto="$3"
    ethcfg_existed="$4"

    ethcfg="${NETSCRIPTS_DIR}/ifcfg-${iface}"
    ovscfg="${NETSCRIPTS_DIR}/ifcfg-${bridge}"

    if [ "$bootproto" != "static" ]; then
        pf="/tmp/dhcpcd-${bridge}.pid"
        if [ -f "$pf" ]; then
            kill "$(cat "$pf")" 2>/dev/null || true
            rm -f "$pf"
        fi
        log_message "Stopped dhclient for ${bridge}"
    fi

    if ovs-vsctl br-exists "$bridge" 2>/dev/null; then
        ip link set "$bridge" down 2>/dev/null || true
        ovs-vsctl del-br "$bridge" 2>/dev/null || true
        log_message "Removed OVS bridge ${bridge}"
    fi

    # DSM's Network Interface UI edits the bridge's ifcfg file (ifcfg-ovs_ethN),
    # not the physical port's, while the bridge exists. Sync whatever the user's
    # most recent change actually was back into ifcfg-ethN - our durable,
    # persistent record for this slot - before we delete the bridge file.
    if [ -f "$ovscfg" ]; then
        live_bootproto=$(get_ifcfg_value "$ovscfg" "BOOTPROTO")
        live_ipv6init=$(get_ifcfg_value "$ovscfg" "IPV6INIT")
        live_ipaddr=$(get_ifcfg_value "$ovscfg" "IPADDR")
        live_netmask=$(get_ifcfg_value "$ovscfg" "NETMASK")

        if [ -n "$live_bootproto" ] && [ "$live_bootproto" != "$bootproto" ]; then
            log_message "${iface}: bootproto changed ${bootproto} -> ${live_bootproto} while bridged, syncing back"
        fi

        [ -n "$live_bootproto" ] && { /usr/syno/bin/synosetkeyvalue "$ethcfg" BOOTPROTO "$live_bootproto" 2>/dev/null || true; }
        [ -n "$live_ipv6init" ] && { /usr/syno/bin/synosetkeyvalue "$ethcfg" IPV6INIT "$live_ipv6init" 2>/dev/null || true; }

        if [ "$live_bootproto" = "static" ]; then
            [ -n "$live_ipaddr" ] && { /usr/syno/bin/synosetkeyvalue "$ethcfg" IPADDR "$live_ipaddr" 2>/dev/null || true; }
            [ -n "$live_netmask" ] && { /usr/syno/bin/synosetkeyvalue "$ethcfg" NETMASK "$live_netmask" 2>/dev/null || true; }
        else
            # DHCP (or unset) - any leftover static fields from a prior config are stale
            sed -i '/^IPADDR=/d;/^NETMASK=/d' "$ethcfg" 2>/dev/null || true
        fi
    fi

    rm -f "$ovscfg"

    if [ "$ethcfg_existed" = "yes" ]; then
        # Only strip the BRIDGE field we added - leave the user's own
        # BOOTPROTO/IPADDR/NETMASK/IPV6INIT preference for this slot untouched.
        sed -i '/^BRIDGE=/d' "$ethcfg" 2>/dev/null || true
    else
        # We created this file fresh at start time - remove it entirely.
        rm -f "$ethcfg"
    fi

    sed -i "/^${iface}\$/d" "$OVS_INTERFACE_CONF" 2>/dev/null || true

    log_message "Reverted ifcfg/OVS registration for ${iface}"
}

inject_and_bind() {
    mkdir -p "$STATE_DIR" 2>/dev/null || true
    : > "${STATE_DIR}/injections" 2>/dev/null || true
    : > "${STATE_DIR}/ovs_bridges" 2>/dev/null || true
    log_message "Starting Aquantia device scan"
    found_any=0

    for dev in /sys/bus/pci/devices/*/; do
        vendor=$(cat "${dev}vendor" 2>/dev/null || true)
        [ "$vendor" = "$AQUANTIA_VENDOR" ] || continue
        found_any=1

        device=$(cat "${dev}device" 2>/dev/null || true)
        [ -n "$device" ] || continue

        vendor_hex=$(echo "${vendor#0x}" | tr 'a-f' 'A-F')
        device_hex=$(echo "${device#0x}" | tr 'a-f' 'A-F')
        target_id="${vendor_hex}:${device_hex}"

        # Already claimed by a driver - either a genuine Synology-branded card
        # (leave alone), or this device was already injected & bound by an
        # earlier run of this script (status/injections state gets wiped on
        # every start, so it must be reconciled here or `status` will never
        # see this device again and DSM will mark the package Manually Stopped
        # even though the card is up and working).
        if [ -e "${dev}driver" ]; then
            existing_driver=$(basename "$(readlink "${dev}driver")" 2>/dev/null || echo "unknown")

            is_ours=0
            for mod in $ATLANTIC_MODULES; do
                [ "$(basename "$mod" .ko)" = "$existing_driver" ] && is_ours=1 && break
            done

            if [ "$is_ours" -eq 0 ]; then
                log_message "${dev} already bound to ${existing_driver}, skipping"
                continue
            fi

            log_message "${dev} already bound to ${existing_driver} from a previous run, reconciling state"

            ifaces=$(wait_for_iface "$dev" || true)
            if [ -z "$ifaces" ]; then
                log_message "${dev} bound to ${existing_driver} but no net interface found, cannot reconcile"
                continue
            fi

            vendor_lc=$(echo "$vendor_hex" | tr 'A-F' 'a-f')
            device_lc=$(echo "$device_hex" | tr 'A-F' 'a-f')
            bdf=$(basename "$dev")
            iface_list=$(echo "$ifaces" | tr '\n' ' ' | sed 's/ *$//')
            echo "${bdf}|${existing_driver}|${vendor_lc}|${device_lc}|${iface_list}" >> "${STATE_DIR}/injections"

            for iface in $ifaces; do
                bridge="ovs_${iface}"
                if ovs-vsctl br-exists "$bridge" 2>/dev/null; then
                    ethcfg="${NETSCRIPTS_DIR}/ifcfg-${iface}"
                    bootproto=$(get_ifcfg_value "$ethcfg" "BOOTPROTO")
                    [ -n "$bootproto" ] || bootproto="dhcp"
                    # This run didn't create ifcfg-<iface>, so mark it as
                    # pre-existing - otherwise a later uninstall would delete
                    # a file we never created.
                    echo "${iface}|${bridge}|${bootproto}|yes" >> "${STATE_DIR}/ovs_bridges"
                    log_message "${bridge} already exists for ${iface}, recorded for status/teardown tracking"
                else
                    create_ovs_bridge_for "$iface"
                fi
            done
            continue
        fi

        matched_module=""
        for mod in $ATLANTIC_MODULES; do
            ids=$(get_supported_ids "$mod" || true)
            if echo "$ids" | grep -qx "$target_id"; then
                matched_module=$(basename "$mod" .ko)
                break
            fi
        done

        if [ -z "$matched_module" ]; then
            log_message "No known atlantic module claims ${vendor}:${device} at ${dev}, skipping"
            continue
        fi

        driver_dir="/sys/bus/pci/drivers/${matched_module}"
        if [ ! -d "$driver_dir" ]; then
            log_message "${matched_module} not currently loaded, skipping ${dev}"
            continue
        fi

        vendor_lc=$(echo "$vendor_hex" | tr 'A-F' 'a-f')
        device_lc=$(echo "$device_hex" | tr 'A-F' 'a-f')

        if echo "${vendor_lc} ${device_lc}" > "${driver_dir}/new_id" 2>/dev/null; then
            log_message "Injected ${vendor_lc}:${device_lc} into ${matched_module} for ${dev}"
        else
            log_message "Failed to write new_id for ${vendor_lc}:${device_lc} on ${matched_module}"
            continue
        fi

        ifaces=$(wait_for_iface "$dev" || true)
        if [ -z "$ifaces" ]; then
            log_message "Timed out waiting for interface to appear for ${dev}, will not be able to fully reverse this injection on stop"
            continue
        fi

        # Record everything needed to fully reverse the new_id injection later:
        # BDF | module | vendor | device | space-separated iface list
        bdf=$(basename "$dev")
        iface_list=$(echo "$ifaces" | tr '\n' ' ' | sed 's/ *$//')
        echo "${bdf}|${matched_module}|${vendor_lc}|${device_lc}|${iface_list}" >> "${STATE_DIR}/injections"

        for iface in $ifaces; do
            create_ovs_bridge_for "$iface"
        done

        # Send DSM notification
        case "${vendor_hex}:${device_hex}" in
            1D6A:00B1)                      card_name="Aquantia AQC100 10G" ;;
            1D6A:07B1|1D6A:D107)            card_name="Aquantia AQC107 10G" ;;
            1D6A:08B1|1D6A:00B1|1D6A:D108)  card_name="Aquantia AQC108 5G" ;;

            1D6A:11B1)                      card_name="Aquantia AQC111 5G" ;;
            1D6A:12B1)                      card_name="Aquantia AQC112 2.5G" ;;

            1D6A:04C0)                      card_name="Aquantia AQC113 10G" ;;
            1D6A:14C0)                      card_name="Aquantia AQC113C 10G" ;;
            1D6A:94C0)                      card_name="Aquantia AQC113CS 10G" ;;

            1D6A:12C0)                      card_name="Aquantia AQC115/AQC115C 2.5G" ;;
            #1D6A:016A)                      card_name="FastLinQ Edge AQC116 1G" ;;  # Not used in PCIe cards

            *)                              card_name="Aquantia device (${vendor_hex}:${device_hex})" ;;
        esac
        synodsmnotify -c SYNO.SDS._ThirdParty.App.AQC_Unlock @users AQC_Unlock:common:title AQC_Unlock:common:loaded "$card_name"
    done

    if [ "$found_any" -eq 0 ]; then
        log_message "No Aquantia (vendor ${AQUANTIA_VENDOR}) PCI devices found on this system"
    fi
}

stop_managed_ifaces() {
    if [ -f "${STATE_DIR}/ovs_bridges" ]; then
        while IFS='|' read -r iface bridge bootproto ethcfg_existed; do
            [ -n "$iface" ] || continue
            teardown_ovs_bridge_for "$iface" "$bridge" "$bootproto" "$ethcfg_existed"
        done < "${STATE_DIR}/ovs_bridges"
        rm -f "${STATE_DIR}/ovs_bridges"
    fi

    if [ ! -f "${STATE_DIR}/injections" ]; then
        log_message "No recorded injections to reverse"
        return 0
    fi

    while IFS='|' read -r bdf module vendor device iface_list; do
        [ -n "$bdf" ] || continue

        driver_dir="/sys/bus/pci/drivers/${module}"

        # Unbind the device from the driver so it returns to its pre-injection state
        if [ -e "/sys/bus/pci/devices/${bdf}/driver" ]; then
            if echo "$bdf" > "${driver_dir}/unbind" 2>/dev/null; then
                log_message "Unbound ${bdf} from ${module}"
            else
                log_message "Failed to unbind ${bdf} from ${module}"
            fi
        fi

        # Remove the dynamic ID entry so the driver no longer auto-claims this ID
        # on any future device add/rescan
        if [ -f "${driver_dir}/remove_id" ]; then
            if echo "${vendor} ${device}" > "${driver_dir}/remove_id" 2>/dev/null; then
                log_message "Removed ${vendor}:${device} from ${module}'s dynamic ID list"
            else
                log_message "Failed to remove ${vendor}:${device} from ${module}'s dynamic ID list"
            fi
        fi
    done < "${STATE_DIR}/injections"

    rm -f "${STATE_DIR}/injections"
}

case "$1" in
    start)
        log_identity
        ensure_modinfo
        inject_and_bind
        exit 0
        ;;
    stop)
        # Deliberately a no-op: new_id injection does NOT survive a reboot, and
        # DSM only auto-restarts a package at boot if it was still running at
        # shutdown. If stop tore everything down, clicking Stop (or the package
        # simply not being running across an unexpected reboot) would leave a
        # user whose only network path is this 10G port unable to reach the NAS
        # at all. Full teardown only happens via the 'uninstall' action, called
        # from preuninstall, where removing the interface entirely is correct.
        log_message "Stop requested - leaving injected interface(s) active (full teardown only happens on package uninstall)"
        exit 0
        ;;
    uninstall)
        log_identity
        cp "$LOG_FILE" "/tmp/AQC_Unlock-uninstall-$(date +%Y%m%d-%H%M%S).log" 2>/dev/null || true
        stop_managed_ifaces
        log_message "Uninstall teardown complete - a copy of the log up to this point was saved under /tmp/AQC_Unlock-uninstall-*.log (the system log via 'logger -t AQC_Unlock' also has every line, including this teardown, and survives after /tmp is cleared on reboot)"
        exit 0
        ;;
    status)
        if [ -f "${STATE_DIR}/injections" ] && [ -s "${STATE_DIR}/injections" ]; then
            exit 0
        else
            exit 3
        fi
        ;;
    killall)
        exit 0
        ;;
    log)
        exit 0
        ;;
esac
